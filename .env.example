# PostgreSQL（容器内默认值，本地开发可改端口为 15432）
DB_HOST=localhost
DB_PORT=15432
DB_NAME=knowsense
DB_USER=knowsense
DB_PASSWORD=knowsense_dev

# Redis
REDIS_URL=redis://localhost:16379/0

# MinIO
MINIO_ENDPOINT=localhost:19000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_dev
MINIO_BUCKET=knowsense-manuals
MINIO_SECURE=false

# LLM — 阶跃星辰（可替换为任意 OpenAI 兼容端点）
LLM_API_URL=https://api.stepfun.com/v1/chat/completions
LLM_API_KEY=你的API密钥
LLM_MODEL=step-3.6

# Embedding — Gitee AI（可替换为任意 OpenAI 兼容端点）
EMBEDDING_API_URL=https://ai.gitee.com/v1/embeddings
EMBEDDING_API_KEY=你的API密钥
EMBEDDING_MODEL=Qwen3-Embedding-0.6B

# PaddleOCR
PADDLEOCR_API_URL=https://paddleocr.aistudio-app.com/api/v2/ocr/jobs
PADDLEOCR_API_KEY=你的API密钥

# JWT
JWT_SECRET=替换为随机字符串
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
